generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  buyer
  seller
  admin
}

model User {
  id           String    @id
  email        String    @unique
  name         String
  role         Role
  organization String
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
  products     Product[]
  quotes       Quote[]
  orders       Order[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Product {
  id                   String          @id
  sellerId             String
  seller               User            @relation(fields: [sellerId], references: [id])
  corridorId           String
  productClass         String
  name                 String
  category             String
  state                String
  origin               String
  imageUrl             String
  unit                 String
  basePrice            Int
  priceVersion         Int             @default(1)
  priceUpdatedAt       DateTime
  procurementFrequency String
  availableQty         String
  specs                String[]
  certifications       String[]
  decisionFactors      String[]
  note                 String
  priceRevisions       PriceRevision[]
  quotes               Quote[]
  orders               Order[]
  sales                SellerSale[]

  @@index([sellerId])
  @@index([category])
  @@index([state])
  @@map("products")
}

model PriceRevision {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  sellerId      String
  previousPrice Int
  newPrice      Int
  reason        String
  effectiveAt   DateTime @default(now())

  @@index([sellerId, effectiveAt(sort: Desc)])
  @@index([productId])
  @@map("price_revisions")
}

model Quote {
  id              String   @id @default(cuid())
  buyerId         String
  buyer           User     @relation(fields: [buyerId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  lots            Int
  freightTier     String
  moverTier       String
  fulfilment      String
  currency        String
  totals          Json
  totalAmount     Float
  rulePackVersion Int
  priceVersion    Int
  status          String   @default("active")
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  order           Order?

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([productId, status])
  @@map("quotes")
}

model Order {
  id            String   @id
  buyerId       String
  buyer         User     @relation(fields: [buyerId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  sellerId      String
  quoteId       String   @unique
  quote         Quote    @relation(fields: [quoteId], references: [id])
  lots          Int
  fulfilment    String
  freightTier   String
  moverTier     String
  currency      String
  totals        Json
  totalAmount   Float
  status        String
  paymentStatus String
  corridorLabel String
  createdAt     DateTime @default(now())

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@map("orders")
}

model SellerSale {
  id            String   @id
  sellerId      String
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  buyerAlias    String
  soldAt        DateTime
  lots          Int
  quantityTons  Float
  amount        Int
  fulfilment    String
  qualityStatus String
  disputeCount  Int

  @@index([sellerId, soldAt(sort: Desc)])
  @@map("seller_sales")
}

model LogisticsPartner {
  id                   String   @id
  type                 String
  legalName            String
  corridor             String
  baseRatePerTon       Int
  distanceRatePerTonKm Float
  capacity             String
  status               String
  lastAudit            DateTime

  @@map("logistics_partners")
}
