{
  "name": "@gctc/api",
  "private": true,
  "version": "2.0.0",
  "description": "Workspace bridge so root npm scripts can drive the Django backend",
  "scripts": {
    "setup": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "dev": ".venv/bin/python manage.py runserver 3000",
    "test": ".venv/bin/python manage.py test trade --verbosity 1",
    "db:migrate": ".venv/bin/python manage.py migrate",
    "db:seed": ".venv/bin/python manage.py seed_demo"
  }
}
