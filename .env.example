# Copy to .env for local development. docker-compose reads this file too.

# --- API ---
DATABASE_URL=postgresql://gctc:gctc@localhost:5433/gctc
SESSION_SECRET=change-me-to-a-random-string-of-at-least-32-chars
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Set true when the API sits behind a reverse proxy (nginx/compose deploy)
TRUST_PROXY=false

# Comma-separated list of allowed browser origins. Not needed when the web
# app is served from the same origin (vite proxy in dev, nginx in prod).
#CORS_ORIGIN=http://localhost:5173

# Traffic controls
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=10
QUOTE_TTL_MINUTES=30
SESSION_TTL_HOURS=168

# --- docker-compose (postgres container) ---
POSTGRES_USER=gctc
POSTGRES_PASSWORD=gctc
POSTGRES_DB=gctc

# Seed demo users and catalogue when the API container starts (demo only)
SEED_ON_BOOT=false
