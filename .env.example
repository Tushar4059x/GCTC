# Copy to .env for local development. docker-compose reads this file too.

# --- API (Django) ---
# For local development, put these in apps/api/.env (loaded by settings.py).
DATABASE_URL=postgresql://gctc:gctc@localhost:5433/gctc
# Django SECRET_KEY; the compose file maps SESSION_SECRET onto it.
SESSION_SECRET=change-me-to-a-random-string-of-at-least-32-chars
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=info

# Set true when the API sits behind a reverse proxy (nginx/compose deploy).
# When true, NUM_PROXIES defaults to 1 so rate limiting keys on the real client
# IP (the hop nginx appends) and cannot be spoofed via X-Forwarded-For.
TRUST_PROXY=false
# Override only if more than one trusted proxy sits in front of the app.
#NUM_PROXIES=1

# Extra origins Django trusts for CSRF when the public host differs from the
# API's own Host header. Same-origin deploys (nginx keeps Host) don't need this.
#CSRF_TRUSTED_ORIGINS=https://gctc.example.com

# Traffic controls
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=10
QUOTE_TTL_MINUTES=30
SESSION_TTL_HOURS=168
# gunicorn worker processes per API container
WEB_CONCURRENCY=4

# --- docker-compose (postgres container) ---
POSTGRES_USER=gctc
# Required — compose refuses to start without it. Use a long random value in
# any shared/production environment (e.g. `openssl rand -hex 24`).
POSTGRES_PASSWORD=change-me-use-a-long-random-value
POSTGRES_DB=gctc

# Seed demo users and catalogue when the API container starts (demo only)
SEED_ON_BOOT=false
